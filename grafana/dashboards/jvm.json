{
  "uid": "jvm-runtime",
  "title": "JVM Runtime (per-instance) — message-gate",
  "tags": ["jvm", "message-gate"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Threads (live / daemon / peak)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "jvm_threads_live_threads{job=\"message-gate\"}", "refId": "A", "legendFormat": "live {{instance}}" },
        { "expr": "jvm_threads_daemon_threads{job=\"message-gate\"}", "refId": "B", "legendFormat": "daemon {{instance}}" },
        { "expr": "jvm_threads_peak_threads{job=\"message-gate\"}", "refId": "C", "legendFormat": "peak {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "CPU usage (process / system)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "process_cpu_usage{job=\"message-gate\"}", "refId": "A", "legendFormat": "process {{instance}}" },
        { "expr": "system_cpu_usage{job=\"message-gate\"}", "refId": "B", "legendFormat": "system {{instance}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.7 },
            { "color": "red", "value": 0.9 }
          ]}
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Classes loaded / Open files",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "jvm_classes_loaded_classes{job=\"message-gate\"}", "refId": "A", "legendFormat": "classes {{instance}}" },
        { "expr": "process_files_open_files{job=\"message-gate\"}", "refId": "B", "legendFormat": "fd open {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Threads by state",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance, state) (jvm_threads_states_threads{job=\"message-gate\"})",
          "refId": "A",
          "legendFormat": "{{instance}} / {{state}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory used by area (heap / nonheap)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance, area) (jvm_memory_used_bytes{job=\"message-gate\"})",
          "refId": "A",
          "legendFormat": "used {{instance}} / {{area}}"
        },
        {
          "expr": "sum by (instance, area) (jvm_memory_committed_bytes{job=\"message-gate\"})",
          "refId": "B",
          "legendFormat": "committed {{instance}} / {{area}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Memory used by pool (G1 Eden / Survivor / Old / Metaspace ...)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"message-gate\"}",
          "refId": "A",
          "legendFormat": "{{instance}} / {{id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "GC pause — count rate & avg duration",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance, action, cause) (rate(jvm_gc_pause_seconds_count{job=\"message-gate\"}[5m]))",
          "refId": "A",
          "legendFormat": "count/s {{instance}} / {{action}} / {{cause}}"
        },
        {
          "expr": "sum by (instance, action) (rate(jvm_gc_pause_seconds_sum{job=\"message-gate\"}[5m])) / clamp_min(sum by (instance, action) (rate(jvm_gc_pause_seconds_count{job=\"message-gate\"}[5m])), 1e-12)",
          "refId": "B",
          "legendFormat": "avg pause(s) {{instance}} / {{action}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "GC overhead (Micrometer % of CPU time)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_gc_overhead{job=\"message-gate\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.1 },
            { "color": "red", "value": 0.3 }
          ]}
        }
      },
      "options": { "legend": { "displayMode": "list" } }
    }
  ]
}
