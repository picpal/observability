{
  "uid": "message-gate-phase1",
  "title": "message-gate Phase 1 (Issue #89) — per-instance",
  "tags": ["message-gate", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 100,
      "type": "stat",
      "title": "instance up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "up{job=\"message-gate\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" }
    },
    {
      "id": 101,
      "type": "stat",
      "title": "AuthCache hit ratio per instance (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (rate(mg_auth_cache_total{outcome=\"hit\"}[5m])) / clamp_min(sum by (instance) (rate(mg_auth_cache_total[5m])), 1e-12)",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.8 },
            { "color": "green", "value": 0.9 }
          ]}
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "id": 102,
      "type": "stat",
      "title": "JVM heap per instance",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (jvm_memory_used_bytes{area=\"heap\", job=\"message-gate\"})",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "id": 103,
      "type": "stat",
      "title": "Idempotency duplicate per instance (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (rate(mg_idempotency_duplicate_total[5m]))",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 1 }
          ]}
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "패널 1 — 통신사 발송 성공률 (per instance × carrier, 5m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance, carrier) (rate(mg_carrier_send_seconds_count{result=\"success\"}[5m])) / clamp_min(sum by (instance, carrier) (rate(mg_carrier_send_seconds_count[5m])), 1e-12)",
          "refId": "A",
          "legendFormat": "{{instance}} / {{carrier}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.9 },
            { "color": "green", "value": 0.95 }
          ]}
        }
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "패널 2 — 통신사 발송 지연 p95/p99 (per instance × carrier)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (instance, carrier, le) (rate(mg_carrier_send_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "p95 {{instance}} / {{carrier}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (instance, carrier, le) (rate(mg_carrier_send_seconds_bucket[5m])))",
          "refId": "B",
          "legendFormat": "p99 {{instance}} / {{carrier}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 1 }
          ]}
        }
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 3,
      "type": "state-timeline",
      "title": "패널 3 — CircuitBreaker 상태 (per instance × name)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{state=~\"closed|open|half_open\"} == 1",
          "refId": "A",
          "legendFormat": "{{instance}} / {{name}} / {{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ACTIVE", "color": "blue" } } }
          ]
        }
      },
      "options": {
        "showValue": "auto",
        "mergeValues": true,
        "rowHeight": 0.9
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "패널 4 — AuthCache outcome rate (per instance × outcome, 5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance, outcome) (rate(mg_auth_cache_total[5m]))",
          "refId": "A",
          "legendFormat": "{{instance}} / {{outcome}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull", "sum"] } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "패널 5 — Grace period 인증 (per instance × NEW/OLD, 5m)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance, password) (rate(mg_grace_auth_total[5m]))",
          "refId": "A",
          "legendFormat": "{{instance}} / {{password}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull", "sum"] } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "패널 6 — Idempotency 중복 거부 rate (per instance, 5m)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (rate(mg_idempotency_duplicate_total[5m]))",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "list" } }
    }
  ]
}
